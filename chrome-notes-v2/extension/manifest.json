{
  "manifest_version": 3,
  "name": "NexusNotes",
  "version": "1.2.0",
  "description": "Tabbed notes with a free local plan and cloud sync after activation.",
  "icons": {
    "32": "icons/browser.png",
    "48": "icons/browser.png",
    "128": "icons/browser.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/browser.png",
      "48": "icons/browser.png",
      "128": "icons/browser.png"
    },
    "default_title": "NexusNotes"
  },
  "permissions": [
    "storage",
    "alarms",
    "windows",
    "tabs"
  ],
  "host_permissions": [
    "https://nexusbackend-ookk.onrender.com/*",
    "https://cex-nexusnotes.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}